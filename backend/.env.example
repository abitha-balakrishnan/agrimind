PORT=5000
MONGODB_URI=mongodb://localhost:27017/agrimind
USE_MEMORY_MONGO=false
CHROMA_URI=http://localhost:8000

# REQUIRED for live AI responses — get your key at https://console.anthropic.com/
# Without a valid key, chat, dashboard, and pest scanner will return errors (not mock data).
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional — enables live weather for your location (https://openweathermap.org/api)
WEATHER_API_KEY=your_openweathermap_api_key_here

TWILIO_ACCOUNT_SID=mock_sid
TWILIO_AUTH_TOKEN=mock_token
TWILIO_PHONE_NUMBER=+1234567890
